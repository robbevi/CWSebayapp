AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

SHAREPOINT_SITE_HOSTNAME=calfrac.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/Supplychain2
SHAREPOINT_LIST_NAME=Williston eBay Inventory
SHAREPOINT_PHOTOS_FOLDER_PATH=General/US Supply Chain/Projects/Ebay Parts Store/eBay App Inventory Photos

# Interim backend (used instead of the SHAREPOINT_*/AZURE_* vars above while IT sets up
# Entra admin consent) — a Google service account with the Sheet and Drive folder below
# shared to its client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=

# Service accounts have no storage quota on a personal (non-Workspace) Google account,
# so uploading photos needs a real OAuth-authenticated identity instead. Client id/secret
# come from a "Desktop app" OAuth client in the same Cloud project; the refresh token is
# produced once via `npm run google:auth -w @warehouse/server` (see README).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

PORT=4000
